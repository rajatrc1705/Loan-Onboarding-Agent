################################################################################
# General OS / Editor junk
################################################################################
.DS_Store
Thumbs.db
Desktop.ini

.idea/
.vscode/
*.swp
*.swo
*.swn
*.tmp
*.log

################################################################################
# Environment / secrets (IMPORTANT)
################################################################################
.env
.env.*
!.env.example
!.env.sample
!.env.template

# Supabase often uses these locally
supabase/.env
supabase/.env.*

################################################################################
# Node / Next.js
################################################################################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

.next/
out/
dist/
build/
.turbo/
.vercel/

# Next.js/Node caches
.cache/
.npm/
.pnpm-store/
.yarn/
*.tsbuildinfo

# Optional: if you generate types into a folder
# types/

################################################################################
# Python / FastAPI
################################################################################
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/
.python-version

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
*.egg-info/
.eggs/
pip-wheel-metadata/

# FastAPI/Uvicorn logs
uvicorn.log
gunicorn.log

################################################################################
# Supabase (local dev artifacts)
################################################################################
# Supabase CLI local DB + volumes (common in local setups)
supabase/.branches/
supabase/.temp/
supabase/.cache/

# If you use a local "data" directory for Postgres volumes, ignore it
# (Only include if you actually have one)
data/
.pgdata/
postgres-data/
db-data/

# If you keep SQL dumps locally
*.sql.dump
*.dump

################################################################################
# Docker (if you use it)
################################################################################
docker-compose.override.yml
**/docker-compose.override.yml

################################################################################
# Logs / runtime junk
################################################################################
logs/
*.pid

################################################################################
# Misc
################################################################################
*.pem
*.key
*.crt
*.p12
*.pfx

# If you use Supabase functions with Deno, you may have a deno cache locally
deno.lock
